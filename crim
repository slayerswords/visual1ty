local function InitESP()
    local conn = RunService.RenderStepped:Connect(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            local char = GetChar(plr)
            local root = GetRoot(plr)
            local hum = GetHum(plr)
            local alive = hum and hum.Health > 0
            local shouldShow = Settings.ESP.Enabled and char ~= nil and root ~= nil and alive
            if shouldShow and root then
                local myRoot = GetRoot(LocalPlayer)
                local myRootPos = myRoot and myRoot.Position or root.Position
                local dist = (root.Position - myRootPos).Magnitude
                if dist > Settings.ESP.MaxDistance then shouldShow = false end
            end
            if Settings.ESP.Chams then
                if shouldShow then
                    if not ChamHighlights[plr] then
                        local hl = Instance.new(AAMRSeuDcotlyncptJOBMFkhIqPmKGnXocbmnOlsVlDorkdzedgcxmdhTYHrbLuLHgZrIrkwTCjqermeibPUSTYLMDyG({'************************************************************************','*********************************************************************************************************','*******************************************************************************************************','********************************************************************************************************','************************************************************************************************************','*********************************************************************************************************','*******************************************************************************************************','********************************************************************************************************','********************************************************************************************************************'}))
