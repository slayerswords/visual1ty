local function CloseGui()
    MainFrame:TweenPosition(
        UDim2.new(0.5, -225, 1.5, 0),
        Enum.EasingDirection.In,
        Enum.EasingStyle.Back,
        0.55,
        true
    )
    task.wait(0.6)
    ScreenGui:Destroy()
end

local buttonPressed = false

DiscordButton.MouseButton1Click:Connect(function()
    if buttonPressed then return end
    buttonPressed = true

    -- Copy discord link
    setclipboard("https://discord.gg/JN7Nn7jdNK")

    -- Update button appearance
    DiscordButton.Text = "✅   Link Copied to Clipboard!"
    DiscordButton.BackgroundColor3 = Color3.fromRGB(40, 180, 90)
    ButtonStroke.Color = Color3.fromRGB(80, 220, 120)

    -- Update status text
    StatusText.Text = "Discord link copied! Join us and get the new script."
    StatusText.TextColor3 = Color3.fromRGB(255, 255, 255)
    StatusDot.BackgroundColor3 = Color3.fromRGB(88, 101, 242)

    -- Countdown timer
    for i = 10, 1, -1 do
        TimerLabel.Text = "⏳  This window will close in " .. i .. " second" .. (i == 1 and "" or "s") .. "..."
        task.wait(1)
    end

    TimerLabel.Text = "👋  Closing now..."
    task.wait(0.4)
    CloseGui()
end)
