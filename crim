local function GetClosestTarget(targetPart, wallCheck, teamCheck, checkDowned, fovEnabled, fovRadius)
    local closest, shortest = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if teamCheck and IsTeam(plr) then continue end
        if not IsAlive(plr) then continue end
        if checkDowned and IsDowned(plr) then continue end
        if HasFF(plr) then continue end
        local c = GetChar(plr)
        local part = c and c:FindFirstChild(targetPart)
        if not part then continue end
        if wallCheck and not IsVisible(part) then continue end
        if fovEnabled then
            local sp, onSc = Camera:WorldToViewportPoint(part.Position)
            if not onSc then continue end
            local d2D = (Vector2.new(sp.X, sp.Y) - center).Magnitude
            if d2D > (fovRadius or 80) then continue end
            if d2D < shortest then closest = plr; shortest = d2D end
        else
            local dist = (Camera.CFrame.Position - part.Position).Magnitude
            if dist < shortest then closest = plr; shortest = dist end
        end
    end
    return closest
end

